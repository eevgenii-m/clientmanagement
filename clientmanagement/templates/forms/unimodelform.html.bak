{% extends "_basenarrow.html" %}
{% load static %}

{% block page_title %}{{ minititle }}{% endblock %}

{% block extra_css %}
<style>
    /* Style Django's generated form fields */
    .tw-form p { margin-bottom: 1rem; }

    .tw-form label {
        display: block;
        font-size: 0.8125rem;
        font-weight: 500;
        color: #475569;
        margin-bottom: 0.3rem;
        font-family: 'DM Sans', sans-serif;
    }

    .tw-form input[type="text"],
    .tw-form input[type="email"],
    .tw-form input[type="tel"],
    .tw-form input[type="number"],
    .tw-form input[type="url"],
    .tw-form select,
    .tw-form textarea {
        display: block;
        width: 100%;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 0.875rem;
        color: #1e293b;
        background: #ffffff;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
        font-family: 'DM Sans', sans-serif;
    }

    .tw-form input:focus,
    .tw-form select:focus,
    .tw-form textarea:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .tw-form .helptext {
        display: block;
        font-size: 0.75rem;
        color: #94a3b8;
        margin-top: 0.25rem;
    }

    .tw-form ul.errorlist {
        list-style: none;
        margin: 0.25rem 0 0;
        padding: 0;
        font-size: 0.75rem;
        color: #dc2626;
    }

    /* Quill editor border radius to match inputs */
    .tw-form .ql-toolbar {
        border-radius: 8px 8px 0 0;
        border-color: #e2e8f0 !important;
        background: #f8fafc;
        font-family: 'DM Sans', sans-serif;
    }
    .tw-form .ql-container {
        border-radius: 0 0 8px 8px;
        border-color: #e2e8f0 !important;
        font-size: 0.875rem;
        font-family: 'DM Sans', sans-serif;
    }
    .tw-form .ql-editor { min-height: 120px; }
</style>
{% endblock %}

{% block body %}

<div class="mb-5">
    <a href="{{ backurl }}"
       class="inline-flex items-center gap-1 text-xs text-slate-500 hover:text-slate-700 transition-colors mb-3">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back
    </a>
    <h1 class="text-xl font-semibold text-slate-800">{{ minititle }}</h1>
</div>

<div class="bg-white rounded-xl border border-slate-200 p-6">
    <form method="POST" class="tw-form" autocomplete="off" enctype="multipart/form-data">
        {% for field in form %}
        {% if field.html_name != 'annoyance' %}
        <p>
            {{ field.label_tag }}
            {{ field }}
            {% if field.help_text and field.html_name != 'phone' %}<span class="helptext">{{ field.help_text }}</span>{% endif %}
            {% if field.html_name == 'phone' %}<span class="helptext">Optional country code: +1 (212) 555-1234 — or with extension: (212) 555-1234 x302</span>{% endif %}
            {% if field.errors %}<ul class="errorlist">{% for error in field.errors %}<li>{{ error }}</li>{% endfor %}</ul>{% endif %}
        </p>
        {% endif %}
        {% endfor %}
        {% csrf_token %}
        <input type="hidden" name="targetid" value="{{ targetid|default:'-1' }}">
        <input type="hidden" name="action" value="{{ action|default:'add' }}">

        <div class="flex items-center gap-3 mt-6 pt-5 border-t border-slate-100">
            <button type="submit"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                {{ submbutton }}
            </button>
            <a href="{{ backurl }}"
               class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                Cancel
            </a>
        </div>
    </form>
</div>

{% if deletebutton %}{% if targetid %}
<div class="mt-4">
    <form method="POST" autocomplete="off" enctype="multipart/form-data">
        {% csrf_token %}
        <input type="hidden" name="targetid" value="{{ targetid|default:'-1' }}">
        <input type="hidden" name="action" value="delete">
        <button type="button"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-red-600 bg-white border border-red-200 rounded-lg hover:bg-red-50 transition-colors"
                onclick="if(confirm('Are you sure you want to delete?')) this.closest('form').submit()">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            {{ deletebutton }}
        </button>
    </form>
</div>
{% endif %}{% endif %}

{% endblock %}
