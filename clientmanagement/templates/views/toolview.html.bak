{% extends "_basewide.html" %}
{% load static %}

{% block page_title %}{{ tool.get_name_for_user }}{% endblock %}

{% block body %}

<!-- Sticky action bar -->
<div class="sticky top-14 z-10 bg-slate-50 -mx-6 px-6 py-3 border-b border-slate-200 mb-6 flex items-center gap-3">

    <a href="{% url 'all_tools' tool_type='' %}"
       class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-700 transition-colors mr-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All tools
    </a>

    <span class="text-sm font-semibold text-slate-800 truncate">{{ tool.get_name_for_user }}</span>

    <div class="flex-1"></div>

    <!-- Edit Tool button -->
    <form action="{% url 'new_tool' tool_type=tool.tool_type_field %}" method="POST" enctype="multipart/form-data" class="inline">
        {% csrf_token %}
        <input type="hidden" name="action" value="change">
        <input type="hidden" name="targetid" value="{{ tool.id }}">
        <button type="submit"
                class="inline-flex items-center gap-2 px-4 py-1.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Edit tool
        </button>
    </form>

</div>

<!-- Tool detail card -->
<div class="max-w-4xl mx-auto bg-white rounded-xl border border-slate-200 overflow-hidden mb-6">

    <div class="px-6 py-5 space-y-4">

        <!-- Type -->
        <div class="flex items-start gap-4">
            <span class="text-xs font-medium text-slate-500 uppercase tracking-wider w-28 shrink-0 pt-0.5">Type</span>
            {% if tool.tool_type_field == 'f' %}
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">File</span>
            {% else %}
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600">Link</span>
            {% endif %}
        </div>

        <!-- Link / Download -->
        {% if tool.get_link %}
        <div class="flex items-start gap-4">
            <span class="text-xs font-medium text-slate-500 uppercase tracking-wider w-28 shrink-0 pt-0.5">
                {% if tool.tool_type_field == 'f' %}File{% else %}Link{% endif %}
            </span>
            <a href="{{ tool.get_link }}" target="_blank"
               class="inline-flex items-center gap-1.5 text-sm text-blue-600 hover:text-blue-800 hover:underline transition-colors break-all">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                {{ tool.get_link_text }}
            </a>
        </div>
        {% endif %}

        <!-- Description -->
        {% if tool.description %}
        <div class="flex items-start gap-4">
            <span class="text-xs font-medium text-slate-500 uppercase tracking-wider w-28 shrink-0 pt-0.5">Description</span>
            <p class="text-sm text-slate-700 whitespace-pre-wrap">{{ tool.description }}</p>
        </div>
        {% endif %}

        <!-- Visibility -->
        <div class="flex items-start gap-4">
            <span class="text-xs font-medium text-slate-500 uppercase tracking-wider w-28 shrink-0 pt-0.5">Visibility</span>
            {% if tool.public %}
                {% if tool.publicinlist %}
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">Public / In list</span>
                {% else %}
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">Public / Hidden</span>
                {% endif %}
            {% else %}
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500">Private</span>
            {% endif %}
        </div>

    </div>

</div>

{% endblock %}
