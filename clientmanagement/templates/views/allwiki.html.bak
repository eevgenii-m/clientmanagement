{% extends "_basenorm.html" %}
{% load static %}

{% block page_title %}Wiki{% endblock %}

{% block extra_css %}
<style>
    /* Lock page scroll — only the DataTable body scrolls */
    html, body { overflow: hidden; height: 100%; }
</style>
{% endblock %}

{% block body %}

<!-- Sticky header: title + search + new article button -->
<div class="sticky top-14 z-10 bg-slate-50 -mx-6 px-6 py-3 border-b border-slate-200 mb-4">
    <div class="max-w-5xl mx-auto flex items-center gap-4">
        <div class="min-w-0">
            <h1 class="text-xl font-semibold text-slate-800 leading-tight">Wiki</h1>
            <p class="text-xs text-slate-500">Knowledge base articles</p>
        </div>

        <!-- Search -->
        <div class="flex-1 relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
            </svg>
            <input type="search" id="wiki-search"
                   placeholder="Search articles…"
                   class="w-full pl-9 pr-4 py-2 text-sm border border-slate-200 rounded-lg bg-white outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 font-sans transition-colors">
        </div>

        <!-- New article button -->
        <a href="{% url 'wiki_new' %}"
           class="shrink-0 inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            New Article
        </a>
    </div>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <table id="wikiart" class="w-full">
        <thead>
            <tr>
                <th>Title</th>
                <th>Updated</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for article in wiki_art %}
            {% include "views/oneitemrow/wikirow.html" with art=article %}
            {% endfor %}
        </tbody>
    </table>
</div>

{% if needdatatables %}
<script>
    $(document).ready(function() {
        var dt = $('#wikiart').DataTable({
            "paging": false,
            "info": false,
            "searching": true,
            "dom": "t",
            "scrollY": "300px",
            "scrollCollapse": true,
            "autoWidth": false,
            "order": [[1, "desc"]],
            "columnDefs": [
                { "orderable": false, "targets": [2] }
            ]
        });

        /* Wire custom search input */
        $('#wiki-search').on('input', function() {
            dt.search(this.value).draw();
        });

        /* Size scroll body to fill remaining viewport */
        function fitTable() {
            var scrollBody = $('#wikiart').closest('.dataTables_wrapper').find('.dataTables_scrollBody');
            if (!scrollBody.length) return;
            var top = scrollBody.offset().top;
            var h = window.innerHeight - top - 8;
            scrollBody.css({ 'height': h + 'px', 'max-height': h + 'px' });
        }
        fitTable();
        $(window).on('resize', fitTable);
    });
</script>
{% endif %}

{% endblock %}
