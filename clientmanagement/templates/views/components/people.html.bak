{% if people %}
<div class="overflow-x-auto">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-slate-100">
                <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider pb-2 pr-4">Name</th>
                <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider pb-2 pr-4">Phone</th>
                <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider pb-2 pr-4">Email</th>
                <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider pb-2 w-20"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
            {% for person in people %}
            {% include "views/oneitemrow/personrow.html" with person=person %}
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<p class="text-sm text-slate-500">No contacts added yet.</p>
{% endif %}

<div class="mt-4 pt-4 border-t border-slate-100">
    <a href="{% url 'clientperson' clientid=clid %}"
       class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add person
    </a>
</div>
