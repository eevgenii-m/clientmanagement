{% extends "_basenorm.html" %}
{% load static %}

{% block page_title %}Shared Files{% endblock %}

{% block extra_css %}
<style>
    html, body { overflow: hidden; height: 100%; }

    #filestable,
    .dataTables_scrollHead table {
        table-layout: fixed !important;
        width: 100% !important;
    }

    #filestable th:nth-child(1) { width: 28%; }   /* Filename     */
    #filestable th:nth-child(2) { width: 22%; }   /* Description  */
    #filestable th:nth-child(3) { width: 10%; }   /* Size         */
    #filestable th:nth-child(4) { width: 10%; }   /* Downloads    */
    #filestable th:nth-child(5) { width: 13%; }   /* Uploaded on  */
    #filestable th:nth-child(6) { width: 13%; }   /* Expires on   */
    #filestable th:nth-child(7) { width: 4%;  }   /* Actions      */

    #filestable .cell-clamp {
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }
</style>
{% endblock %}

{% block body %}

<!-- Sticky header -->
<div class="sticky top-14 z-10 bg-slate-50 -mx-6 px-6 py-3 border-b border-slate-200 mb-4">
    <div class="max-w-5xl mx-auto flex items-center gap-3 flex-wrap">

        <div class="min-w-0 shrink-0">
            <h1 class="text-xl font-semibold text-slate-800 leading-tight">Shared Files</h1>
            <p class="text-xs text-slate-500">Temporary file sharing</p>
        </div>

        <!-- Search -->
        <div class="flex-1 relative min-w-[160px]">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
            </svg>
            <input type="search" id="files-search"
                   placeholder="Search files…"
                   class="w-full pl-9 pr-4 py-2 text-sm border border-slate-200 rounded-lg bg-white outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 font-sans transition-colors">
        </div>

        <!-- Upload button -->
        {% if user.is_authenticated %}
        <a href="{% url 'upload_shared_file' %}"
           class="shrink-0 inline-flex items-center gap-1.5 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Upload File
        </a>
        {% endif %}

    </div>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <table id="filestable" class="w-full">
        <thead>
            <tr>
                <th>Filename</th>
                <th>Description</th>
                <th>Size</th>
                <th>Downloads</th>
                <th>Uploaded on</th>
                <th>Expires on</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for sf in files %}
            <tr class="hover:bg-slate-50 transition-colors {% if sf.is_expired %}opacity-50{% endif %}">

                <!-- Filename -->
                <td class="font-medium text-slate-800" title="{{ sf.filename_display }}">
                    <div class="cell-clamp">
                        <a href="{% url 'download_shared_file' fileuuid=sf.unid %}"
                           class="text-blue-600 hover:text-blue-800 hover:underline transition-colors">
                            {{ sf.filename_display }}
                        </a>
                        {% if sf.is_expired %}
                        <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-red-50 text-red-600">Expired</span>
                        {% endif %}
                    </div>
                </td>

                <!-- Description -->
                <td title="{{ sf.description }}">
                    <div class="cell-clamp text-sm text-slate-500">{{ sf.description|default:"—" }}</div>
                </td>

                <!-- Size -->
                <td class="text-sm text-slate-500 tabular-nums">{{ sf.file_size_display }}</td>

                <!-- Downloads -->
                <td class="text-sm text-slate-500 tabular-nums">{{ sf.downloads }}</td>

                <!-- Uploaded on -->
                <td class="text-sm text-slate-500 tabular-nums">{{ sf.createdon|date:"Y-m-d" }}</td>

                <!-- Expires on -->
                <td class="text-sm tabular-nums {% if sf.is_expired %}text-red-500{% else %}text-slate-500{% endif %}">
                    {{ sf.expireon|date:"Y-m-d"|default:"Never" }}
                </td>

                <!-- Actions -->
                <td>
                    {% if user.is_authenticated %}
                    <form method="POST" action="{% url 'delete_shared_file' fileid=sf.id %}" class="inline">
                        {% csrf_token %}
                        <button type="button"
                                class="inline-flex items-center px-2 py-1 text-xs font-medium text-red-600 bg-white border border-red-200 rounded-md hover:bg-red-50 transition-colors"
                                onclick="if(confirm('Delete {{ sf.filename_display }}?')) this.closest('form').submit()">
                            Del
                        </button>
                    </form>
                    {% endif %}
                </td>

            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% if needdatatables %}
<script>
    $(document).ready(function() {
        var dt = $('#filestable').DataTable({
            "paging": false,
            "info": false,
            "searching": true,
            "dom": "t",
            "scrollY": "300px",
            "scrollCollapse": true,
            "autoWidth": false,
            "order": [[4, "desc"]],
            "columnDefs": [
                { "orderable": false, "targets": [1, 6] }
            ]
        });

        $('#files-search').on('input', function() {
            dt.search(this.value).draw();
        });

        function fitTable() {
            var scrollBody = $('#filestable').closest('.dataTables_wrapper').find('.dataTables_scrollBody');
            if (!scrollBody.length) return;
            var top = scrollBody.offset().top;
            var h = window.innerHeight - top - 8;
            scrollBody.css({ 'height': h + 'px', 'max-height': h + 'px' });
        }
        fitTable();
        $(window).on('resize', fitTable);
    });
</script>
{% endif %}

{% endblock %}
